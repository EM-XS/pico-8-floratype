pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
	--modes/screens of the game:
	--1 field
	--2 calendar
	atn, atx = 0, 32
	memset(0x8000, 0, 0x4000)
	cls()
	init_field_screen()
	init_calendar_screen()
	
	start_field_screen()
end

function _update()
	atn = (atn + 1) % atx
	if menu_is_open then
		update_seed_menu()
	else
		if mode == 1 then
			update_field_screen()
		elseif mode == 2 then
			update_calendar_screen()
		end
	end
end

function _draw()
	if mode == 1 then
		draw_field_screen()
	elseif mode == 2 then
		draw_calendar_screen()
	end
	if menu_is_open then
		draw_seed_menu()
	end
end

function save_game()
	--store sprite sheet, map and
	--sprite flags to this cart
--	cstore(0x0,0x0,0x30ff)
	
	--store sprites and map in a
	--save file
	cstore(0x0,0x0,0x30ff,"floratype_save.p8")
end


