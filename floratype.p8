--flowers and genes

--primary and secondary colors
--for different color phenotypes
flower_colors = {
	{8,14},
	{12,1},
	{9,10},
	{2,13}
}

gene_start = 6
gene_sizes = {1,1}

flower_class = {}
flower_class.__index = flower_class

function flower_class:new(genes)
	return setmetatable(
		{
			genes=genes,
		},
		self)
end

function flower_class:place(fn, x, y)
	self.fn, self.x, self.y = fn, x, y
end

function flower_class:get_alleles(offset, size)
	local bit_shift = 16 - gene_start - offset
	local shifted_genes = self.genes << bit_shift
	local allele_max = 2 << (size - 1) - 1
	return shifted_genes & allele_max, (shifted_genes >> size) & allele_max
end

function flower_class:type()
	return self.genes << 16 & 0b1
end

function flower_class:color_gene()
	-- color gene expression
	-- 0 0 -> red
	-- 0 1 -> blue
	-- 1 1 -> yellow
	local a1, a2 = self:get_alleles(0,1)
	return a1 + a2
end

function flower_class:dark_gene()
	-- dark gene expression
	-- dark (1) is recessive
	-- 0 0 -> light
	-- 0 1 -> light
	-- 1 1 -> dark
	local a1, a2 = self:get_alleles(2,1)
	return a1 * a2
end

function flower_class:color()
	--if the flower has the dark gene
	--it's always purple. otherwise
	--it's the color dictated by the
	--color gene
	if self:dark_gene() == 1 then
		return 3
	else
		return self:color_gene()
	end
end

function flower_class:is_compatible(flower)
	return self:type() == flower:type()
end

function generate_flower(flower_type)
	--right now, this uses a
	--one of two template image
	--and recolors into 1 of 4
	--color palettes.

	--randomly pick any one of
	--16 gene sequences possible
	local c = flr(rnd(16))

	-- bit 1 from the right is flower type
	local genes = flower_type >>> 16
	-- bits 7-10 from the right are the color
	genes += c >>> 10
	
	return flower_class:new(genes)
end

function spr_pos(s)
	--get sprite sheet position
	--from sprite number
	return s % 16 * 8, s \ 16 * 8
end

function breed(flower1, flower2)
	local genes, offset = 0, 0
	--take the flower type from a parent
	genes += flower1.genes & (0b1 >> 16)
	
	--go gene by gene, taking one
	--allele from each parent
	for size in all(gene_sizes) do
		local a1 = rnd(pack(flower1:get_alleles(offset,size)))
		local a2 = rnd(pack(flower2:get_alleles(offset,size)))
		local alleles = a1 + (a2 << size)
		genes += alleles >> 16 - gene_start - offset
		offset += size*2
	end
	return flower_class:new(genes)
end

function gene_str(genes)
	return tostr(genes, true)
end

local swap_sprite = 110
local swap_x, swap_y = spr_pos(swap_sprite)


function create_flower_sprite(flower)
	--genetics contains 32 bits,
	--meanings:
	--bit 1: flower type
	--bits 2-3: color
	--bits 4-32: unused
	local template = 32 + flower:type() * 2
	local c = flower:color()

	local tx, ty = spr_pos(template)
	--sprite sheet local of swap sprite
	--always must immediately copy this somewhere
	--as it will be overwritten on next
	--call to create_sprite
	
	--write to the sprite sheet
	for x=0,15 do
		for y=0,15 do
			local pc = sget(tx+x,ty+y)
			if pc == 5 then
				pc = flower_colors[c+1][1]
			elseif pc == 6  then
				pc = flower_colors[c+1][2]
			end
			sset(swap_x+x,swap_y+y,pc)
		end
	end
end

function create_and_place_flower_sprite(flower, sx, sy)
	local screen_x, screen_y = sx and sx or flower.x - fcam_x, sy and sy or flower.y - fcam_y
	if sx or (screen_x >= 0 and screen_x <= 7 and screen_y >= 0 and screen_y <= 6) then
		create_flower_sprite(flower)
		--copy sprite to correct location in
		--extended sprite sheet 0
		blit(
			0x8000,
			screen_x * 16, screen_y * 16,
			0x0000,
			swap_x, swap_y,
			16, 16
		)
	end
end

function remove_flower_sprite(x, y, sx, sy)
	--the bottom of extended sprite sheet 0
	--should be empty, so copy 0s from there
	--i think this is more efficient than
	--using memset since we need to
	--remove each row of pixels
	--todo: there's a lot of reuse between
	--this and the function above - possibly
	--can refactor to save tokens
	local screen_x, screen_y = sx and sx or x - fcam_x, sy and sy or y - fcam_y
	blit(
		0x8000,
		screen_x * 16, screen_y * 16,
		0xa000,
		0, 0,
		16, 16
	)
end
